    private PageSectionDefinition CloneElement(PageSectionDefinition source)
    {
        var clone = JsonSerializer.Deserialize<PageSectionDefinition>(
            JsonSerializer.Serialize(source, JsonOptions),
            JsonOptions) ?? CreateElement(source.Type);
        AssignNewIds(clone);
        return clone;
    }

    private static void AssignNewIds(PageSectionDefinition element)
    {
        element.Id = Guid.NewGuid().ToString("n");
        foreach (var child in element.Children)
        {
            AssignNewIds(child);
        }
    }

    private List<PageSectionDefinition>? GetChildren(string? parentId)
    {
        return parentId is null ? pageLayout.Sections : FindElement(parentId)?.Children;
    }

    private PageSectionDefinition? FindElement(string id)
    {
        return FindElementContext(id)?.Node;
    }

    private ElementContext? FindElementContext(string id)
    {
        return FindElementContext(id, pageLayout.Sections, null, 0);
    }

    private static ElementContext? FindElementContext(string id, List<PageSectionDefinition> siblings, string? parentId, int depth)
    {
        for (var i = 0; i < siblings.Count; i++)
        {
            var element = siblings[i];
            if (element.Id == id)
            {
                return new ElementContext(element, siblings, i, parentId, depth);
            }

            var child = FindElementContext(id, element.Children, element.Id, depth + 1);
            if (child is not null)
            {
                return child;
            }
        }

        return null;
    }

    private bool IsDescendantOf(string elementId, string ancestorId)
    {
        var ancestor = FindElement(ancestorId);
        return ancestor is not null && ContainsElement(ancestor.Children, elementId);
    }

    private static bool ContainsElement(IEnumerable<PageSectionDefinition> elements, string id)
    {
        foreach (var element in elements)
        {
            if (element.Id == id || ContainsElement(element.Children, id))
            {
                return true;
            }
        }

        return false;
    }

    private void NormalizeLayout()
    {
        pageLayout.PageId = string.IsNullOrWhiteSpace(pageLayout.PageId) ? PageId.ToString("n") : pageLayout.PageId;
        NormalizeElements(pageLayout.Sections);
        SyncNavigationElements(pageLayout.Sections);
    }

    private static void NormalizeElements(List<PageSectionDefinition> elements)
    {
        for (var i = 0; i < elements.Count; i++)
        {
            elements[i].Id = string.IsNullOrWhiteSpace(elements[i].Id) ? Guid.NewGuid().ToString("n") : elements[i].Id;
            elements[i].Order = i + 1;
            elements[i].Props ??= [];
            elements[i].Styles ??= [];
            elements[i].Children ??= [];
            NormalizeElements(elements[i].Children);
        }
    }

    private void SyncNavigationElements(IEnumerable<PageSectionDefinition> elements)
    {
        foreach (var element in elements)
        {
            if (element.Type.Equals("navBar", StringComparison.OrdinalIgnoreCase))
            {
                SyncNavigationElement(element);
            }

            SyncNavigationElements(element.Children);
        }
    }

    private void SyncNavigationElement(PageSectionDefinition element)
    {
        var useStoreName = !element.Props.TryGetPropertyValue("useStoreName", out var useStoreNode) ||
            useStoreNode is not JsonValue useStoreValue ||
            !useStoreValue.TryGetValue<bool>(out var useStoreNameValue) ||
            useStoreNameValue;
        var autoLinks = !element.Props.TryGetPropertyValue("autoLinks", out var autoLinksNode) ||
            autoLinksNode is not JsonValue autoLinksValue ||
            !autoLinksValue.TryGetValue<bool>(out var autoLinksEnabled) ||
            autoLinksEnabled;

        if (useStoreName && currentStore is not null)
        {
            element.Props["brand"] = currentStore.Name;
        }

        if (autoLinks && sitePages is not null)
        {
            element.Props["links"] = new JsonArray(sitePages
                .OrderByDescending(page => page.IsHomePage)
                .ThenBy(page => page.Title)
                .Select(page => new JsonObject
                {
                    ["text"] = page.IsHomePage ? "Home" : page.Title,
                    ["url"] = page.IsHomePage ? "/" : page.Slug
                })
                .ToArray<JsonNode?>());
        }

        element.Props["useStoreName"] ??= true;
        element.Props["autoLinks"] ??= true;
        element.Props["showLogo"] ??= true;
        element.Props["logoUrl"] ??= string.Empty;
        element.Props["logoAlt"] ??= string.Empty;
        element.Props["logoSize"] ??= "42px";
        element.Props["logoPlacement"] ??= "beforeName";
        element.Props["hideBrandText"] ??= false;
        element.Props["brandPosition"] ??= "left";
        element.Props["linksPosition"] ??= "center";
        element.Props["ctaPosition"] ??= "right";
        element.Props["navLayout"] ??= "spread";
        element.Props["navPosition"] ??= "normal";
        element.Props["navWidth"] ??= "contained";
        element.Props["linksAlignment"] ??= "center";
        element.Props["navTop"] ??= "0px";
    }

    private int CountElements(IEnumerable<PageSectionDefinition> elements)
    {
        var count = 0;
        foreach (var element in elements)
        {
            count++;
            count += CountElements(element.Children);
        }

        return count;
    }

    private void PushHistory()
    {
        undoStack.Push(Snapshot());
        redoStack.Clear();
        while (undoStack.Count > 60)
        {
            undoStack.TryPop(out _);
        }
    }

    private string Snapshot()
    {
        return JsonSerializer.Serialize(pageLayout, JsonOptions);
    }

    private void ApplySnapshot(string json)
    {
        pageLayout = JsonSerializer.Deserialize<PageLayoutDocument>(json, JsonOptions) ?? new PageLayoutDocument { PageId = PageId.ToString("n") };
        NormalizeLayout();
        selectedElementId = SelectedElement is not null ? selectedElementId : pageLayout.Sections.FirstOrDefault()?.Id;
        SyncInspectorJson();
    }

    private void SyncInspectorJson()
    {
        if (SelectedElement is null)
        {
            propsJson = "{}";
            stylesJson = "{}";
            return;
        }

        propsJson = JsonSerializer.Serialize(SelectedElement.Props, JsonOptions);
        stylesJson = JsonSerializer.Serialize(SelectedElement.Styles, JsonOptions);
    }

    private void MarkDirty()
    {
        hasChanges = true;
        message = null;
    }

    private readonly record struct ElementContext(
        PageSectionDefinition Node,
        List<PageSectionDefinition> Siblings,
        int Index,
        string? ParentId,
        int Depth);

    private sealed class EditorInteractionState
    {
        public string ElementId { get; set; } = string.Empty;
        public EditorInteractionKind Kind { get; set; }
        public string? Handle { get; set; }
        public long PointerId { get; set; }
        public double StartClientX { get; set; }
        public double StartClientY { get; set; }
        public EditorElementBox StartBox { get; set; } = new(string.Empty, 0, 0, 0, 0, 0, true, false);
        public EditorElementBox CurrentBox { get; set; } = new(string.Empty, 0, 0, 0, 0, 0, true, false);
        public bool PreserveAspectRatio { get; set; }
        public bool HasMoved { get; set; }
    }
