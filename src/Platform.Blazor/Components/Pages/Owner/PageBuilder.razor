    private void ChangeSelectedZIndex(int delta)
    {
        if (selectedElementId is not null)
        {
            ChangeElementZIndex(selectedElementId, delta);
        }
    }

    private void HandleZIndexRequest(EditorZIndexRequest request)
    {
        switch (request.Change)
        {
            case EditorZIndexChange.Forward:
                ChangeElementZIndex(request.ElementId, 1);
                break;
            case EditorZIndexChange.Backward:
                ChangeElementZIndex(request.ElementId, -1);
                break;
            case EditorZIndexChange.Front:
                SetElementZIndex(request.ElementId, NextZIndex());
                break;
            case EditorZIndexChange.Back:
                SetElementZIndex(request.ElementId, Math.Max(0, LowestZIndex() - 1));
                break;
        }
    }

    private void BringSelectedToFront()
    {
        if (selectedElementId is not null)
        {
            SetElementZIndex(selectedElementId, NextZIndex());
        }
    }

    private void SendSelectedToBack()
    {
        if (selectedElementId is not null)
        {
            SetElementZIndex(selectedElementId, Math.Max(0, LowestZIndex() - 1));
        }
    }

    private void ChangeElementZIndex(string elementId, int delta)
    {
        if (GetElementBox(elementId) is not { } box)
        {
            return;
        }

        SetElementZIndex(elementId, Math.Max(0, box.ZIndex + delta));
    }

    private void SetElementZIndex(string elementId, int zIndex)
    {
        var element = FindElement(elementId);
        var box = GetElementBox(elementId);
        if (element is null || box is null || box.IsLocked)
        {
            return;
        }

        PushHistory();
        EditorGeometry.ApplyBox(element, box with { ZIndex = zIndex });
        SelectElement(elementId);
        SyncInspectorJson();
        MarkDirty();
    }

    private int LowestZIndex()
    {
        return EnumerateEditorBoxes(pageLayout.Sections).Select(box => box.ZIndex).DefaultIfEmpty(1).Min();
    }

    private void NudgeSelectedElement(double deltaX, double deltaY)
    {
        if (SelectedElement is null || SelectedBox is not { } box || box.IsLocked)
        {
            return;
        }

        PushHistory();
        var updated = box with
        {
            X = box.X + deltaX,
            Y = box.Y + deltaY
        };
        EditorGeometry.ApplyBox(SelectedElement, EditorGeometry.ClampToCanvas(updated, CanvasModelWidth, Math.Max(CanvasHeight, updated.Y + updated.Height + 96)));
        SyncInspectorJson();
        MarkDirty();
    }

    private void ApplyJson()
    {
        if (SelectedElement is null)
        {
            return;
        }

        error = null;
        try
        {
            var props = JsonNode.Parse(string.IsNullOrWhiteSpace(propsJson) ? "{}" : propsJson) as JsonObject
                ?? throw new InvalidOperationException("Props JSON must be an object.");
            var styles = JsonNode.Parse(string.IsNullOrWhiteSpace(stylesJson) ? "{}" : stylesJson) as JsonObject
                ?? throw new InvalidOperationException("Styles JSON must be an object.");

            PushHistory();
            SelectedElement.Props = props;
            SelectedElement.Styles = styles;
            SyncInspectorJson();
            MarkDirty();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void UpdatePaletteDrop(double clientX, double clientY)
    {
        paletteDropX = Math.Clamp((clientX - canvasRect.Left) / ZoomScale, 0, Math.Max(0, CanvasModelWidth - 120));
        paletteDropY = Math.Clamp((clientY - canvasRect.Top) / ZoomScale, 0, Math.Max(0, EffectiveCanvasHeight - 80));
    }

    private EditorElementBox? GetElementBox(string elementId)
    {
        if (liveBoxes.TryGetValue(elementId, out var live))
        {
            return live;
        }

        var context = FindElementContext(elementId);
        return context is null ? null : EditorGeometry.GetBox(context.Value.Node, context.Value.Index, context.Value.Depth);
    }

    private bool ShouldRenderElementInEditor(string elementId)
    {
        return showHiddenElements ||
               selectedElementId == elementId ||
               GetElementBox(elementId)?.IsVisible != false;
    }

    private double NextAvailableY(string? parentId)
    {
        var target = GetChildren(parentId) ?? [];
        return target.Select((section, index) => EditorGeometry.GetBox(section, index, parentId is null ? 0 : 1))
            .Select(box => box.Y + box.Height)
            .DefaultIfEmpty(0)
            .Max() + 24;
    }

    private int NextZIndex()
    {
        return EnumerateEditorBoxes(pageLayout.Sections).Select(box => box.ZIndex).DefaultIfEmpty(0).Max() + 1;
    }

    private IEnumerable<EditorElementBox> EnumerateEditorBoxes(IEnumerable<PageSectionDefinition> elements, int depth = 0)
    {
        var index = 0;
        foreach (var element in elements)
        {
            yield return liveBoxes.TryGetValue(element.Id, out var live) ? live : EditorGeometry.GetBox(element, index, depth);
            foreach (var child in EnumerateEditorBoxes(element.Children, depth + 1))
            {
                yield return child;
            }

            index++;
        }
    }

    private static EditorElementBox ResizeBox(EditorElementBox start, string handle, double deltaX, double deltaY, bool preserveAspectRatio)
    {
        var x = start.X;
        var y = start.Y;
        var width = start.Width;
        var height = start.Height;

        if (handle.Contains("e", StringComparison.OrdinalIgnoreCase))
        {
            width = start.Width + deltaX;
        }

        if (handle.Contains("s", StringComparison.OrdinalIgnoreCase))
        {
            height = start.Height + deltaY;
        }

        if (handle.Contains("w", StringComparison.OrdinalIgnoreCase))
        {
            x = start.X + deltaX;
            width = start.Width - deltaX;
            if (width < EditorGeometry.MinWidth)
            {
                x = start.X + start.Width - EditorGeometry.MinWidth;
                width = EditorGeometry.MinWidth;
            }
        }

        if (handle.Contains("n", StringComparison.OrdinalIgnoreCase))
        {
            y = start.Y + deltaY;
            height = start.Height - deltaY;
            if (height < EditorGeometry.MinHeight)
            {
                y = start.Y + start.Height - EditorGeometry.MinHeight;
                height = EditorGeometry.MinHeight;
            }
        }

        if (preserveAspectRatio && start.Height > 0)
        {
            var ratio = start.Width / start.Height;
            var adjusted = ApplyAspectRatio(start, handle, x, y, width, height, ratio);
            x = adjusted.X;
            y = adjusted.Y;
            width = adjusted.Width;
            height = adjusted.Height;
        }

        return start with
        {
            X = x,
            Y = y,
            Width = Math.Max(EditorGeometry.MinWidth, width),
            Height = Math.Max(EditorGeometry.MinHeight, height)
        };
    }

    private static EditorElementBox ApplyAspectRatio(EditorElementBox start, string handle, double x, double y, double width, double height, double ratio)
    {
        var usesHorizontal = handle.Contains("e", StringComparison.OrdinalIgnoreCase) || handle.Contains("w", StringComparison.OrdinalIgnoreCase);
        var usesVertical = handle.Contains("n", StringComparison.OrdinalIgnoreCase) || handle.Contains("s", StringComparison.OrdinalIgnoreCase);

        if (!usesHorizontal && !usesVertical)
        {
            return start with { X = x, Y = y, Width = width, Height = height };
        }

        if (usesHorizontal && (!usesVertical || Math.Abs(width - start.Width) >= Math.Abs(height - start.Height) * ratio))
        {
            height = width / ratio;
        }
        else
        {
            width = height * ratio;
        }

        if (handle.Contains("w", StringComparison.OrdinalIgnoreCase))
        {
            x = start.X + start.Width - width;
        }

        if (handle.Contains("n", StringComparison.OrdinalIgnoreCase))
        {
            y = start.Y + start.Height - height;
        }

        return start with { X = x, Y = y, Width = width, Height = height };
    }

    private static bool HasMeaningfulMovement(EditorElementBox start, EditorElementBox current)
    {
        return Math.Abs(start.X - current.X) > .5 ||
               Math.Abs(start.Y - current.Y) > .5 ||
               Math.Abs(start.Width - current.Width) > .5 ||
               Math.Abs(start.Height - current.Height) > .5;
    }

    private static bool IsAspectRatioResizeElement(PageSectionDefinition element)
    {
        return element.Type.Equals("image", StringComparison.OrdinalIgnoreCase);
    }

    private async Task<EditorCanvasRect> GetCanvasRectAsync()
    {
        try
        {
            var rect = await JS.InvokeAsync<EditorCanvasRect>("platformBuilder.getRect", canvasRef);
            if (rect.Width > 0 && rect.Height > 0)
            {
                canvasRectMeasured = true;
                return rect;
            }

            canvasRectMeasured = false;
            return new EditorCanvasRect { Width = DefaultCanvasModelWidth * ZoomScale, Height = CanvasHeight * ZoomScale };
        }
        catch
        {
            canvasRectMeasured = false;
            return new EditorCanvasRect { Width = DefaultCanvasModelWidth * ZoomScale, Height = CanvasHeight * ZoomScale };
        }
    }

    private async Task CapturePointerAsync(long pointerId)
    {
        try
        {
            await JS.InvokeVoidAsync("platformBuilder.capturePointer", canvasRef, pointerId);
        }
        catch
        {
            // Pointer capture is a progressive enhancement for fast drags.
        }
    }

    private async Task ReleasePointerAsync(long pointerId)
    {
        try
        {
            await JS.InvokeVoidAsync("platformBuilder.releasePointer", canvasRef, pointerId);
        }
        catch
        {
            // The browser may already have released the pointer.
        }
    }

    private async Task FocusCanvasAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("platformBuilder.focusElement", canvasRef);
        }
        catch
        {
            // Keyboard shortcuts still work when focus is already inside the editor.
        }
    }

    private PageSectionDefinition CreateElement(string? type)
    {
        type = NormalizeElementType(type);
        var element = new PageSectionDefinition
        {
            Id = Guid.NewGuid().ToString("n"),
            Type = type,
            Props = DefaultProps(type),
            Styles = DefaultStyles(type)
        };

        if (string.Equals(type, "form", StringComparison.OrdinalIgnoreCase))
        {
            element.Children.Add(CreateElement("input"));
        }

        return element;
    }

    private static string NormalizeElementType(string? type)
    {
        return string.IsNullOrWhiteSpace(type) ? DefaultElementType : type;
    }

