    private void Undo()
    {
        if (undoStack.Count == 0)
        {
            return;
        }

        redoStack.Push(Snapshot());
        ApplySnapshot(undoStack.Pop());
        MarkDirty();
    }

    private void Redo()
    {
        if (redoStack.Count == 0)
        {
            return;
        }

        undoStack.Push(Snapshot());
        ApplySnapshot(redoStack.Pop());
        MarkDirty();
    }

    private async Task Save(bool publish)
    {
        busy = true;
        error = null;
        message = null;
        NormalizeLayout();
        pageLayout.PageId = PageId.ToString("n");

        var request = new SavePageLayoutRequest
        {
            Publish = publish,
            LayoutJson = JsonSerializer.Serialize(pageLayout, JsonOptions)
        };

        try
        {
            var saved = await Api.PostAsync<SavePageLayoutRequest, PageLayoutDto>($"api/stores/{StoreId}/pages/{PageId}/layout", request);
            if (saved?.Layout is not null)
            {
                pageLayout = saved.Layout;
                NormalizeLayout();
            }

            undoStack.Clear();
            redoStack.Clear();
            hasChanges = false;
            SyncInspectorJson();
            message = publish ? $"Published version {saved?.Version}." : $"Saved draft version {saved?.Version}.";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

