@page "/owner/{StoreId:guid}/pages/{PageId:guid}/builder"
@page "/dashboard/stores/{StoreId:guid}/page-builder/{PageId:guid}"
@attribute [ClientAuthorize(Roles = "StoreOwner,StoreStaff,PlatformAdmin")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using System.Text.Json
@using System.Text.Json.Nodes
@inject PlatformApiClient Api
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Page Builder</PageTitle>

<div class="editor-shell" tabindex="0" @onkeydown="HandleEditorKeyDown" @onclick="ClearSelection">
    <header class="editor-topbar" @onclick:stopPropagation="true" @onkeydown:stopPropagation="true">
        <div>
            <a class="editor-back" href="/owner/@StoreId/pages">Pages</a>
            <h1>@(currentPage?.Title ?? "Page Builder")</h1>
            @if (currentPage is not null)
            {
                <span class="editor-page-slug">/@currentPage.Slug</span>
            }
            <span class="editor-status @(hasChanges ? "dirty" : "saved")">@(hasChanges ? "Unsaved changes" : "Saved")</span>
        </div>
        <div class="editor-actions">
            <button type="button" class="btn btn-outline-secondary" disabled="@(!CanUndo)" @onclick="Undo">Undo</button>
            <button type="button" class="btn btn-outline-secondary" disabled="@(!CanRedo)" @onclick="Redo">Redo</button>
            @if (!string.IsNullOrWhiteSpace(PreviewUrl))
            {
                <a class="btn btn-outline-secondary" href="@PreviewUrl" target="_blank">Preview</a>
            }
            <button type="button" class="btn btn-outline-primary" disabled="@busy" @onclick="() => Save(false)">Save draft</button>
            <button type="button" class="btn btn-primary" disabled="@busy" @onclick="() => Save(true)">Publish</button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="editor-toast error" @onclick:stopPropagation="true">@error</div>
    }
    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="editor-toast success" @onclick:stopPropagation="true">@message</div>
    }

    <div class="editor-workspace @(leftPanelOpen ? "" : "left-collapsed") @(inspectorOpen ? "" : "right-collapsed")">
        <aside class="editor-sidebar @(leftPanelOpen ? "" : "is-collapsed")" @onclick:stopPropagation="true" @onkeydown:stopPropagation="true">
            <button type="button" class="editor-panel-rail editor-panel-rail-left" title="Open Add elements" @onclick="ToggleLeftPanel">
                <span>Add</span>
            </button>
            <div class="editor-panel-content">
                <div class="editor-panel-close-row">
                    <strong>@LeftPanelTitle</strong>
                    <button type="button" title="Hide Add elements panel" @onclick="ToggleLeftPanel">Hide</button>
                </div>
                <nav class="editor-left-tabs" aria-label="Builder panels">
                    <button type="button" class="@(IsLeftPanel("add") ? "active" : "")" @onclick="ShowAddPanel">Add</button>
                    <button type="button" class="@(IsLeftPanel("layers") ? "active" : "")" @onclick="ShowLayersPanel">Layers</button>
                    <button type="button" class="@(IsLeftPanel("pages") ? "active" : "")" @onclick="ShowPagesPanel">Pages</button>
                </nav>

                @if (IsLeftPanel("pages"))
                {
                    <section class="editor-site-panel">
                        <div class="editor-panel-heading">
                            <h2>Site pages</h2>
                            <span>@(sitePages?.Count ?? 0) pages</span>
                        </div>
                        <div class="editor-site-pages">
                            @foreach (var pageItem in sitePages ?? [])
                            {
                                <a class="@(pageItem.Id == PageId ? "active" : "")" href="@($"/owner/{StoreId}/pages/{pageItem.Id}/builder")">
                                    <strong>@pageItem.Title</strong>
                                    <small>@pageItem.Slug @(pageItem.IsHomePage ? "Home" : "")</small>
                                </a>
                            }
                        </div>
                        <div class="editor-site-actions">
                            <a class="btn btn-sm btn-outline-primary w-100" href="/owner/@StoreId/pages">Create page</a>
                            <button type="button" class="btn btn-sm btn-outline-secondary w-100" disabled="@HasNavigation" @onclick="AddStoreNavigation">Add store navigation</button>
                        </div>
                    </section>
                }
                else if (IsLeftPanel("layers"))
                {
                    <section class="editor-layers-panel">
                        <div class="editor-panel-heading">
                            <h2>Layers</h2>
                            <span>@CountElements(pageLayout.Sections) items</span>
                        </div>
                        @if (pageLayout.Sections.Count == 0)
                        {
                            <div class="editor-panel-empty">
                                <strong>No layers yet</strong>
                                <span>Add elements to build the page structure.</span>
                            </div>
                        }
                        else
                        {
                            @RenderLayerTree(pageLayout.Sections, 0)
                        }
                    </section>
                }
                else
                {
                    <div class="editor-panel-heading">
                        <h2>Add elements</h2>
                        <span>Drag or click</span>
                    </div>
                    <input class="form-control form-control-sm editor-search" placeholder="Search elements" @bind="searchText" @bind:event="oninput" />
                    @foreach (var group in FilteredGroups)
                    {
                        <section class="editor-element-group">
                            <h3>@group</h3>
                            <div class="editor-element-grid">
                                @foreach (var component in FilteredComponents.Where(x => x.Group == group))
                                {
                                    <article class="editor-element-card"
                                             draggable="true"
                                             @ondragstart="() => StartComponentDrag(component.Type)"
                                             @ondragend="ClearDrag">
                                        <span>@component.Icon</span>
                                        <div>
                                            <strong>@component.Name</strong>
                                            <small>@component.Description</small>
                                        </div>
                                        <button type="button" title="Add to page" @onclick:stopPropagation="true" @onclick="() => InsertElement(component.Type, null, pageLayout.Sections.Count)">Add</button>
                                    </article>
                                }
                            </div>
                        </section>
                    }
                }
            </div>
        </aside>

        <main class="editor-stage" @onclick:stopPropagation="true">
            <div class="editor-stage-toolbar">
                <div class="editor-canvas-title">
                    <strong>Canvas</strong>
                    <span>@(CountElements(pageLayout.Sections)) elements</span>
                    @if (SelectedBox is not null)
                    {
                        <span class="editor-selection-readout">
                            X @Math.Round(SelectedBox.X) Y @Math.Round(SelectedBox.Y) W @Math.Round(SelectedBox.Width) H @Math.Round(SelectedBox.Height)
                        </span>
                    }
                </div>
                <div class="editor-stage-tools">
                    <div class="editor-panel-toggles" aria-label="Builder panels">
                        <button type="button" class="@(leftPanelOpen ? "active" : "")" @onclick="ToggleLeftPanel">Add / Layers</button>
                        <button type="button" class="@(inspectorOpen ? "active" : "")" @onclick="ToggleInspector">Settings</button>
                    </div>
                    <div class="editor-zoom-controls" aria-label="Canvas zoom">
                        <button type="button" title="Zoom out" @onclick="ZoomOut">-</button>
                        <button type="button" title="Reset zoom" @onclick="ResetZoom">@zoomPercent%</button>
                        <button type="button" title="Zoom in" @onclick="ZoomIn">+</button>
                    </div>
                    <label class="editor-snap-control">
                        <span>Snap</span>
                        <input type="number" min="0" max="32" value="@snapDistance" @onchange="args => SetSnapDistance(args.Value?.ToString())" />
                    </label>
                    <label class="editor-show-hidden-control">
                        <input type="checkbox" checked="@showHiddenElements" @onchange="args => showHiddenElements = args.Value is true" />
                        <span>Show hidden</span>
                    </label>
                    <div class="editor-device-switch">
                        <button type="button" class="@(deviceMode == "desktop" ? "active" : "")" @onclick="SetDesktop">Desktop</button>
                        <button type="button" class="@(deviceMode == "tablet" ? "active" : "")" @onclick="SetTablet">Tablet</button>
                        <button type="button" class="@(deviceMode == "mobile" ? "active" : "")" @onclick="SetMobile">Mobile</button>
                    </div>
                </div>
            </div>

            <div class="editor-canvas-wrap">
                <section @ref="canvasRef"
                         class="editor-canvas @deviceMode @(draggedComponentType is not null ? "is-palette-dragging" : "")"
                         style="@CanvasStyle"
                         tabindex="0"
                         @ondragenter="HandleCanvasDragEnter"
                         @ondragover="HandleCanvasDragOver"
                         @ondragover:preventDefault="true"
                         @ondragleave="HandleCanvasDragLeave"
                         @ondrop="HandleCanvasDrop"
                         @ondrop:preventDefault="true"
                         @onpointermove="HandlePointerMove"
                         @onpointerup="HandlePointerUp"
                         @onpointercancel="HandlePointerCancel">
                    <div class="editor-canvas-background" @onclick="ClearSelection"></div>
                    @foreach (var guide in alignmentGuides)
                    {
                        <div class="editor-alignment-guide @(guide.Axis == "x" ? "vertical" : "horizontal")"
                             style="@(guide.Axis == "x" ? $"left:{EditorGeometry.FormatPixel(guide.Position)}" : $"top:{EditorGeometry.FormatPixel(guide.Position)}")"></div>
                    }
                    @if (showCanvasDropIndicator)
                    {
                        <div class="editor-canvas-drop-indicator"
                             style="left:@EditorGeometry.FormatPixel(paletteDropX);top:@EditorGeometry.FormatPixel(paletteDropY)">
                            <span>@draggedComponentType</span>
                        </div>
                    }
                    @if (!HasNavigation)
                    {
                        <div class="editor-nav-prompt">
                            <div>
                                <strong>No store navigation on this page</strong>
                                <span>Add a header so shoppers can move between Home, Shop, Cart, and other pages.</span>
                            </div>
                            <button type="button" class="btn btn-sm btn-primary" @onclick="AddStoreNavigation">Add header</button>
                        </div>
                    }

                    @DropZone(new EditorDropTarget(null, 0), pageLayout.Sections.Count == 0)

                    @if (pageLayout.Sections.Count == 0)
                    {
                        <div class="editor-empty-canvas">
                            <strong>Start designing</strong>
                            <span>Drag sections, text, media, buttons, forms, or commerce blocks here.</span>
                        </div>
                    }

                    @for (var i = 0; i < pageLayout.Sections.Count; i++)
                    {
                        var index = i;
                        var section = pageLayout.Sections[index];
                        if (ShouldRenderElementInEditor(section.Id))
                        {
                            <EditorCanvasNode Section="section"
                                              ParentId="@null"
                                              Index="index"
                                              Depth="0"
                                              SelectedElementId="@selectedElementId"
                                              ActiveDropTarget="@activeDropTarget"
                                              LiveBoxes="@liveBoxes"
                                              StoreKey="@(currentStore?.Slug ?? string.Empty)"
                                              ShowHiddenElements="@showHiddenElements"
                                              SelectRequested="SelectElement"
                                              InteractionStarted="BeginElementInteraction"
                                              DropRequested="HandleDrop"
                                              DropTargetChanged="SetActiveDropTarget"
                                              DuplicateRequested="DuplicateElement"
                                              DeleteRequested="DeleteElement"
                                              ToggleVisibilityRequested="ToggleElementVisibility"
                                              ToggleLockRequested="ToggleElementLock"
                                              ZIndexRequested="HandleZIndexRequest"
                                              InlineEditRequested="HandleInlineEdit"
                                              MoveRequested="MoveElement" />
                        }
                        @DropZone(new EditorDropTarget(null, index + 1), false)
                    }
                </section>
            </div>
        </main>

        <aside class="editor-inspector @(inspectorOpen ? "" : "is-collapsed")" @onclick:stopPropagation="true" @onkeydown:stopPropagation="true">
            <button type="button" class="editor-panel-rail editor-panel-rail-right" title="Open Settings" @onclick="ToggleInspector">
                <span>Settings</span>
            </button>
            <div class="editor-panel-content">
                <div class="editor-panel-heading">
                    <h2>Settings</h2>
                    @if (SelectedElement is not null)
                    {
                        <span>@EditorComponentCatalog.Get(SelectedElement.Type).Name</span>
                    }
                    <button type="button" class="editor-panel-heading-action" title="Hide Settings panel" @onclick="ToggleInspector">Hide</button>
                </div>

                @if (SelectedElement is null)
                {
                    <div class="editor-inspector-empty">
                        <strong>No element selected</strong>
                        <span>Select an element on the canvas to edit its content and style.</span>
                    </div>
                }
                else
                {
                    var selectedBox = SelectedBox;
                    <div class="editor-selected-summary">
                        <strong>@EditorComponentCatalog.Get(SelectedElement.Type).Name</strong>
                        <code>@SelectedElement.Id</code>
                    </div>
                    <div class="editor-selected-toolbar">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CopySelectedElement">Copy</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(!CanPaste)" @onclick="PasteCopiedElement">Paste</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => DuplicateElement(SelectedElement.Id)">Duplicate</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(selectedBox?.IsLocked == true)" @onclick="() => DeleteElement(SelectedElement.Id)">Delete</button>
                    </div>

                    @if (selectedBox is not null)
                    {
                        <section class="editor-fieldset">
                            <h3>Layout</h3>
                            <div class="editor-layout-grid">
                                @LayoutNumberField("X", "left", selectedBox.X)
                                @LayoutNumberField("Y", "top", selectedBox.Y)
                                @LayoutNumberField("W", "width", selectedBox.Width)
                                @LayoutNumberField("H", "height", selectedBox.Height)
                                @LayoutNumberField("Z", "zIndex", selectedBox.ZIndex)
                                @LayoutNumberField("Snap", "snapDistance", snapDistance)
                            </div>
                            <div class="editor-toggle-row">
                                <div class="editor-visibility-control" aria-label="Element visibility">
                                    <span>Visibility</span>
                                    <button type="button"
                                            class="@(selectedBox.IsVisible ? "active" : "")"
                                            @onclick="() => SetElementVisibility(true)">
                                        Shown
                                    </button>
                                    <button type="button"
                                            class="@(!selectedBox.IsVisible ? "active danger" : "")"
                                            @onclick="() => SetElementVisibility(false)">
                                        Hidden
                                    </button>
                                </div>
                                <label>
                                    <input type="checkbox" checked="@selectedBox.IsLocked" @onchange="args => SetElementLock(args.Value is true)" />
                                    <span>Locked</span>
                                </label>
                            </div>
                            <div class="editor-inspector-actions">
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => ChangeSelectedZIndex(1)">Forward</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => ChangeSelectedZIndex(-1)">Backward</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="BringSelectedToFront">To front</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SendSelectedToBack">To back</button>
                            </div>
                        </section>
                    }

                    <section class="editor-fieldset">
                        <h3>Content</h3>
                        @RenderContentFields(SelectedElement)
                    </section>

                    <section class="editor-fieldset">
                        <h3>Style</h3>
                        @StyleField("Background", "backgroundColor", "#ffffff", "color")
                        @StyleField("Text color", "color", "#111827", "color")
                        @StyleField("Padding", "padding", "24px")
                        @StyleField("Margin", "margin", "")
                        @StyleField("Radius", "borderRadius", "8px")
                        @StyleField("Border", "border", "")
                        @StyleField("Shadow", "boxShadow", "")
                        @StyleField("Opacity", "opacity", "1", "number")
                        @StyleField("Font size", "fontSize", "")
                        @StyleField("Font family", "fontFamily", "")
                        @StyleSelect("Weight", "fontWeight", ["normal", "500", "600", "700"])
                        @StyleField("Line height", "lineHeight", "")
                        @StyleSelect("Alignment", "textAlign", ["left", "center", "right"])
                    </section>

                    <details class="editor-advanced">
                        <summary>Advanced JSON</summary>
                        <label>Props JSON</label>
                        <textarea class="form-control font-monospace" rows="8" @bind="propsJson"></textarea>
                        <label>Styles JSON</label>
                        <textarea class="form-control font-monospace" rows="6" @bind="stylesJson"></textarea>
                        <button type="button" class="btn btn-outline-primary w-100 mt-2" @onclick="ApplyJson">Apply JSON</button>
                    </details>
                }
            </div>
        </aside>
    </div>
</div>

@code {
    [Parameter] public Guid StoreId { get; set; }
    [Parameter] public Guid PageId { get; set; }

    private static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web) { WriteIndented = true };
    private readonly Stack<string> undoStack = new();
    private readonly Stack<string> redoStack = new();
    private readonly Dictionary<string, EditorElementBox> liveBoxes = [];
    private PageLayoutDocument pageLayout = new();
    private IReadOnlyCollection<PageDto>? sitePages;
    private PageDto? currentPage;
    private StoreDto? currentStore;
    private ElementReference canvasRef;
    private EditorCanvasRect canvasRect = new() { Width = EditorGeometry.DefaultCanvasWidth, Height = EditorGeometry.DefaultCanvasHeight };
    private bool canvasRectMeasured;
    private EditorInteractionState? activeInteraction;
    private IReadOnlyList<EditorGuide> alignmentGuides = [];
    private string? selectedElementId;
    private string? draggedComponentType;
    private string? draggedElementId;
    private EditorDropTarget? activeDropTarget;
    private string? activeLiveEditKey;
    private string propsJson = "{}";
    private string stylesJson = "{}";
    private string searchText = string.Empty;
    private string activeLeftPanel = "add";
    private string? copiedElementJson;
    private string deviceMode = "desktop";
    private string? error;
    private string? message;
    private int snapDistance = EditorGeometry.DefaultSnapDistance;
    private int zoomPercent = 100;
    private double paletteDropX;
    private double paletteDropY;
    private bool leftPanelOpen;
    private bool inspectorOpen;
    private bool showHiddenElements;
    private bool showCanvasDropIndicator;
    private bool busy;
    private bool hasChanges;

    private PageSectionDefinition? SelectedElement => selectedElementId is null ? null : FindElement(selectedElementId);
    private EditorElementBox? SelectedBox => selectedElementId is null ? null : GetElementBox(selectedElementId);
    private double CanvasHeight => Math.Max(EditorGeometry.DefaultCanvasHeight, pageLayout.Sections.Select((section, index) =>
    {
        var box = liveBoxes.TryGetValue(section.Id, out var live) ? live : EditorGeometry.GetBox(section, index);
        return box.Y + box.Height + 96;
    }).DefaultIfEmpty(EditorGeometry.DefaultCanvasHeight).Max());
    private double ZoomScale => Math.Max(.5, zoomPercent / 100d);
    private double DefaultCanvasModelWidth => deviceMode switch
    {
        "mobile" => 430,
        "tablet" => 820,
        _ => EditorGeometry.DefaultCanvasWidth
    };
    private double CanvasModelWidth => canvasRectMeasured ? canvasRect.Width / ZoomScale : DefaultCanvasModelWidth;
    private double CanvasModelHeight => canvasRectMeasured ? canvasRect.Height / ZoomScale : CanvasHeight;
    private double EffectiveCanvasHeight => Math.Max(CanvasModelHeight, CanvasHeight);
    private bool CanUndo => undoStack.Count > 0;
    private bool CanRedo => redoStack.Count > 0;
    private bool CanPaste => !string.IsNullOrWhiteSpace(copiedElementJson);
    private bool HasNavigation => pageLayout.Sections.Any(section => section.Type.Equals("navBar", StringComparison.OrdinalIgnoreCase));
    private string CanvasStyle => string.Create(CultureInfo.InvariantCulture, $"min-height:{EditorGeometry.FormatPixel(CanvasHeight)};transform:scale({ZoomScale:0.##});");
    private string? PreviewUrl => currentStore is null || currentPage is null
        ? null
        : currentPage.IsHomePage
            ? $"/store/{currentStore.Slug}"
            : $"/store/{currentStore.Slug}/pages/{currentPage.Slug}";
    private static readonly HashSet<string> NumericPropKeys = new(StringComparer.OrdinalIgnoreCase) { "columns", "limit" };
    private static readonly HashSet<string> CommaSeparatedArrayPropKeys = new(StringComparer.OrdinalIgnoreCase) { "links" };
    private const string DefaultElementType = "text";
    private IEnumerable<EditorComponentDefinition> FilteredComponents => string.IsNullOrWhiteSpace(searchText)
        ? EditorComponentCatalog.All
        : EditorComponentCatalog.All.Where(component =>
            component.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            component.Type.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            component.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase));
    private IEnumerable<string> FilteredGroups => FilteredComponents.Select(component => component.Group).Distinct();
    private string LeftPanelTitle => activeLeftPanel switch
    {
        "layers" => "Layers",
        "pages" => "Pages",
        _ => "Add elements"
    };

    private bool IsLeftPanel(string panel) => activeLeftPanel.Equals(panel, StringComparison.OrdinalIgnoreCase);

    private void ShowAddPanel() => activeLeftPanel = "add";

    private void ShowLayersPanel() => activeLeftPanel = "layers";

    private void ShowPagesPanel() => activeLeftPanel = "pages";

    private void ToggleLeftPanel() => leftPanelOpen = !leftPanelOpen;

    private void ToggleInspector() => inspectorOpen = !inspectorOpen;

    private void ZoomOut() => SetZoom(zoomPercent - 10);

    private void ZoomIn() => SetZoom(zoomPercent + 10);

    private void ResetZoom() => SetZoom(100);

    private void SetZoom(int value)
    {
        zoomPercent = Math.Clamp(value, 50, 150);
        canvasRectMeasured = false;
    }

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        error = null;
        try
        {
            var latest = await Api.GetAsync<PageLayoutDto?>($"api/stores/{StoreId}/pages/{PageId}/layout");
            sitePages = await Api.GetAsync<IReadOnlyCollection<PageDto>>($"api/stores/{StoreId}/pages") ?? [];
            currentPage = sitePages.SingleOrDefault(page => page.Id == PageId);
            currentStore = await Api.GetAsync<StoreDto>($"api/stores/{StoreId}");
            pageLayout = latest?.Layout ?? new PageLayoutDocument { PageId = PageId.ToString("n") };
            NormalizeLayout();
            selectedElementId = pageLayout.Sections.FirstOrDefault()?.Id;
            SyncInspectorJson();
            hasChanges = false;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task StartComponentDrag(string? type)
    {
        if (string.IsNullOrWhiteSpace(type))
        {
            draggedComponentType = null;
            error = "That element type is not available.";
            return;
        }

        draggedComponentType = type;
        draggedElementId = null;
        canvasRect = await GetCanvasRectAsync();
        showCanvasDropIndicator = false;
        message = null;
    }

    private void StartElementDrag(string elementId)
    {
        draggedElementId = elementId;
        draggedComponentType = null;
        message = null;
    }

    private void ClearDrag()
    {
        draggedComponentType = null;
        draggedElementId = null;
        activeDropTarget = null;
        showCanvasDropIndicator = false;
    }

    private void SetActiveDropTarget(EditorDropTarget? target)
    {
        activeDropTarget = target is not null && CanDrop(target) ? target : null;
    }

    private void HandleDrop(EditorDropTarget target)
    {
        if (!CanDrop(target))
        {
            ClearDrag();
            return;
        }

        if (!string.IsNullOrWhiteSpace(draggedComponentType))
        {
            InsertElement(draggedComponentType, target.ParentId, target.Index);
        }
        else if (!string.IsNullOrWhiteSpace(draggedElementId))
        {
            MoveElementTo(draggedElementId, target.ParentId, target.Index);
        }

        ClearDrag();
    }

    private void HandleCanvasDragEnter()
    {
        showCanvasDropIndicator = draggedComponentType is not null;
    }

    private void HandleCanvasDragOver(DragEventArgs args)
    {
        if (draggedComponentType is null)
        {
            return;
        }

        SetActiveDropTarget(null);
        UpdatePaletteDrop(args.ClientX, args.ClientY);
        showCanvasDropIndicator = true;
    }

    private void HandleCanvasDragLeave()
    {
        showCanvasDropIndicator = false;
    }

    private async Task HandleCanvasDrop(DragEventArgs args)
    {
        if (draggedComponentType is null)
        {
            return;
        }

        canvasRect = await GetCanvasRectAsync();
        UpdatePaletteDrop(args.ClientX, args.ClientY);
        InsertElement(draggedComponentType, null, pageLayout.Sections.Count, paletteDropX, paletteDropY);
        ClearDrag();
    }

    private async Task BeginElementInteraction(EditorInteractionRequest request)
    {
        var context = FindElementContext(request.ElementId);
        if (context is null)
        {
            return;
        }

        var box = EditorGeometry.GetBox(context.Value.Node, context.Value.Index, context.Value.Depth);
        if (box.IsLocked)
        {
            SelectElement(request.ElementId);
            return;
        }

        SelectElement(request.ElementId);
        canvasRect = await GetCanvasRectAsync();
        activeInteraction = new EditorInteractionState
        {
            ElementId = request.ElementId,
            Kind = request.Kind,
            Handle = request.Handle,
            PointerId = request.PointerId,
            StartClientX = request.ClientX,
            StartClientY = request.ClientY,
            StartBox = box,
            CurrentBox = box,
            PreserveAspectRatio = request.PreserveAspectRatio && IsAspectRatioResizeElement(context.Value.Node)
        };
        liveBoxes[request.ElementId] = box;
        alignmentGuides = [];
        await CapturePointerAsync(request.PointerId);
    }

    private void HandlePointerMove(PointerEventArgs args)
    {
        if (activeInteraction is null)
        {
            return;
        }

        var deltaX = (args.ClientX - activeInteraction.StartClientX) / ZoomScale;
        var deltaY = (args.ClientY - activeInteraction.StartClientY) / ZoomScale;
        var proposed = activeInteraction.Kind == EditorInteractionKind.Resize
            ? ResizeBox(activeInteraction.StartBox, activeInteraction.Handle ?? string.Empty, deltaX, deltaY, activeInteraction.PreserveAspectRatio)
            : activeInteraction.StartBox with
            {
                X = activeInteraction.StartBox.X + deltaX,
                Y = activeInteraction.StartBox.Y + deltaY
            };

        proposed = EditorGeometry.ClampToCanvas(proposed, CanvasModelWidth, EffectiveCanvasHeight);
        var snap = EditorGeometry.Snap(
            proposed,
            EnumerateEditorBoxes(pageLayout.Sections).Where(box => box.ElementId != activeInteraction.ElementId && box.IsVisible),
            CanvasModelWidth,
            EffectiveCanvasHeight,
            snapDistance,
            activeInteraction.Kind == EditorInteractionKind.Resize ? activeInteraction.Handle : null);

        if (!activeInteraction.HasMoved && HasMeaningfulMovement(activeInteraction.StartBox, snap.Box))
        {
            PushHistory();
            activeInteraction.HasMoved = true;
        }

        if (!activeInteraction.HasMoved)
        {
            return;
        }

        activeInteraction.CurrentBox = snap.Box;
        liveBoxes[activeInteraction.ElementId] = snap.Box;
        alignmentGuides = snap.Guides;
    }

    private async Task HandlePointerUp(PointerEventArgs args)
    {
        await CompletePointerInteraction(args.PointerId);
    }

    private async Task HandlePointerCancel(PointerEventArgs args)
    {
        await CompletePointerInteraction(args.PointerId);
    }

    private async Task CompletePointerInteraction(long pointerId)
    {
        if (activeInteraction is null)
        {
            return;
        }

        if (activeInteraction.HasMoved)
        {
            if (FindElement(activeInteraction.ElementId) is { } element &&
                liveBoxes.TryGetValue(activeInteraction.ElementId, out var finalBox))
            {
                EditorGeometry.ApplyBox(element, finalBox);
                MarkDirty();
            }

            SyncInspectorJson();
        }

        liveBoxes.Remove(activeInteraction.ElementId);
        alignmentGuides = [];
        activeInteraction = null;
        await ReleasePointerAsync(pointerId);
    }

    private RenderFragment DropZone(EditorDropTarget target, bool large) => @<div class="editor-drop-zone root @(large ? "large" : "") @(IsActiveDrop(target) ? "active" : "")"
        @ondragenter="() => SetActiveDropTarget(target)"
        @ondragover:preventDefault="true"
        @ondrop:stopPropagation="true"
        @ondrop="() => HandleDrop(target)">
    </div>;

    private RenderFragment RenderLayerTree(IReadOnlyList<PageSectionDefinition> elements, int depth) => @<div class="editor-layer-list">
        @for (var i = 0; i < elements.Count; i++)
        {
            var element = elements[i];
            var definition = EditorComponentCatalog.Get(element.Type);
            var box = GetElementBox(element.Id) ?? EditorGeometry.GetBox(element, i, depth);
            <div class="editor-layer-row @(selectedElementId == element.Id ? "active" : "") @(box.IsVisible ? "" : "is-hidden") @(box.IsLocked ? "is-locked" : "")"
                 style="--layer-depth:@depth">
                <button type="button" class="editor-layer-main" @onclick="() => SelectElement(element.Id)">
                    <span>@definition.Icon</span>
                    <strong>@definition.Name</strong>
                    <small>@(box.IsVisible ? $"{Math.Round(box.X)}, {Math.Round(box.Y)}" : "Hidden")</small>
                </button>
                <div class="editor-layer-actions">
                    <button type="button" title="Toggle visibility" @onclick="() => ToggleElementVisibility(element.Id)">@(box.IsVisible ? "Hide" : "Show")</button>
                    <button type="button" title="Toggle lock" @onclick="() => ToggleElementLock(element.Id)">@(box.IsLocked ? "Unlock" : "Lock")</button>
                    <button type="button" title="Duplicate" @onclick="() => DuplicateElement(element.Id)">Copy</button>
                    <button type="button" title="Delete" disabled="@box.IsLocked" @onclick="() => DeleteElement(element.Id)">Del</button>
                </div>
            </div>
            @if (element.Children.Count > 0)
            {
                @RenderLayerTree(element.Children, depth + 1)
            }
        }
    </div>;

    private bool IsActiveDrop(EditorDropTarget target)
    {
        return activeDropTarget is not null &&
               activeDropTarget.ParentId == target.ParentId &&
               activeDropTarget.Index == target.Index;
    }

    private bool CanDrop(EditorDropTarget target)
    {
        if (target.ParentId is not null)
        {
            var parent = FindElement(target.ParentId);
            if (parent is null || !EditorComponentCatalog.CanContainChildren(parent.Type))
            {
                return false;
            }
        }

        if (draggedElementId is null)
        {
            return true;
        }

        if (draggedElementId == target.ParentId)
        {
            return false;
        }

        return target.ParentId is null || !IsDescendantOf(target.ParentId, draggedElementId);
    }

    private void InsertElement(string? type, string? parentId, int index)
    {
        InsertElement(type, parentId, index, null, null);
    }

    private void InsertElement(string? type, string? parentId, int index, double? x, double? y)
    {
        if (string.IsNullOrWhiteSpace(type))
        {
            error = "Choose an element before adding it to the canvas.";
            return;
        }

        var target = GetChildren(parentId);
        if (target is null)
        {
            return;
        }

        PushHistory();
        var element = CreateElement(type);
        index = Math.Clamp(index, 0, target.Count);
        var defaultBox = EditorGeometry.GetBox(element, index, parentId is null ? 0 : 1);
        var placedBox = defaultBox with
        {
            X = Math.Max(0, x ?? 24),
            Y = Math.Max(0, y ?? NextAvailableY(parentId)),
            ZIndex = NextZIndex()
        };
        EditorGeometry.ApplyBox(element, EditorGeometry.ClampToCanvas(
            placedBox,
            parentId is null ? CanvasModelWidth : defaultBox.Width + placedBox.X,
            Math.Max(CanvasHeight, placedBox.Y + placedBox.Height + 96)));
        target.Insert(index, element);
        NormalizeLayout();
        SelectElement(element.Id);
        MarkDirty();
    }

    private void MoveElement(EditorMoveRequest request)
    {
        var context = FindElementContext(request.ElementId);
        if (context is null)
        {
            return;
        }

        var targetIndex = request.Offset < 0 ? context.Value.Index - 1 : context.Value.Index + 2;
        MoveElementTo(request.ElementId, context.Value.ParentId, targetIndex);
    }

    private void MoveElementTo(string elementId, string? parentId, int targetIndex)
    {
        var source = FindElementContext(elementId);
        var target = GetChildren(parentId);
        if (source is null || target is null)
        {
            return;
        }

        if (source.Value.ParentId == parentId && (targetIndex == source.Value.Index || targetIndex == source.Value.Index + 1))
        {
            return;
        }

        PushHistory();
        var element = source.Value.Siblings[source.Value.Index];
        source.Value.Siblings.RemoveAt(source.Value.Index);
        if (ReferenceEquals(source.Value.Siblings, target) && targetIndex > source.Value.Index)
        {
            targetIndex--;
        }

        targetIndex = Math.Clamp(targetIndex, 0, target.Count);
        target.Insert(targetIndex, element);
        NormalizeLayout();
        SelectElement(element.Id);
        MarkDirty();
    }

    private void DuplicateElement(string elementId)
    {
        var context = FindElementContext(elementId);
        if (context is null)
        {
            return;
        }

        PushHistory();
        var copy = CloneElement(context.Value.Node);
        var copyBox = EditorGeometry.GetBox(copy, context.Value.Index + 1, context.Value.Depth) with
        {
            X = EditorGeometry.GetBox(context.Value.Node, context.Value.Index, context.Value.Depth).X + 24,
            Y = EditorGeometry.GetBox(context.Value.Node, context.Value.Index, context.Value.Depth).Y + 24,
            ZIndex = NextZIndex()
        };
        EditorGeometry.ApplyBox(copy, EditorGeometry.ClampToCanvas(copyBox, CanvasModelWidth, Math.Max(CanvasHeight, copyBox.Y + copyBox.Height + 96)));
        context.Value.Siblings.Insert(context.Value.Index + 1, copy);
        NormalizeLayout();
        SelectElement(copy.Id);
        MarkDirty();
    }

    private void DeleteElement(string elementId)
    {
        var context = FindElementContext(elementId);
        if (context is null)
        {
            return;
        }

        PushHistory();
        context.Value.Siblings.RemoveAt(context.Value.Index);
        NormalizeLayout();
        selectedElementId = context.Value.Siblings.ElementAtOrDefault(Math.Min(context.Value.Index, context.Value.Siblings.Count - 1))?.Id
            ?? pageLayout.Sections.FirstOrDefault()?.Id;
        SyncInspectorJson();
        MarkDirty();
    }

    private void CopySelectedElement()
    {
        if (SelectedElement is null)
        {
            return;
        }

        copiedElementJson = JsonSerializer.Serialize(SelectedElement, JsonOptions);
        message = "Element copied.";
    }

    private void PasteCopiedElement()
    {
        if (string.IsNullOrWhiteSpace(copiedElementJson))
        {
            return;
        }

        error = null;
        try
        {
            var source = JsonSerializer.Deserialize<PageSectionDefinition>(copiedElementJson, JsonOptions);
            if (source is null)
            {
                return;
            }

            var selectedContext = selectedElementId is null ? null : FindElementContext(selectedElementId);
            var parentId = selectedContext?.ParentId;
            var target = GetChildren(parentId) ?? pageLayout.Sections;
            var insertIndex = selectedContext is null ? target.Count : selectedContext.Value.Index + 1;
            var copy = CloneElement(source);
            var sourceBox = selectedContext is null
                ? EditorGeometry.GetBox(copy, insertIndex, parentId is null ? 0 : 1)
                : EditorGeometry.GetBox(selectedContext.Value.Node, selectedContext.Value.Index, selectedContext.Value.Depth);
            var pastedBox = sourceBox with
            {
                ElementId = copy.Id,
                X = sourceBox.X + 24,
                Y = sourceBox.Y + 24,
                ZIndex = NextZIndex(),
                IsLocked = false
            };

            PushHistory();
            EditorGeometry.ApplyBox(copy, EditorGeometry.ClampToCanvas(pastedBox, CanvasModelWidth, Math.Max(CanvasHeight, pastedBox.Y + pastedBox.Height + 96)));
            target.Insert(Math.Clamp(insertIndex, 0, target.Count), copy);
            NormalizeLayout();
            SelectElement(copy.Id);
            MarkDirty();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void SelectElement(string elementId)
    {
        EndLiveEdit();
        selectedElementId = elementId;
        SyncInspectorJson();
        _ = FocusCanvasAsync();
    }

    private void ClearSelection()
    {
        EndLiveEdit();
        selectedElementId = null;
        SyncInspectorJson();
    }

    private void HandleEditorKeyDown(KeyboardEventArgs args)
    {
        var hasCommandKey = args.CtrlKey || args.MetaKey;
        if (hasCommandKey && args.Key.Equals("z", StringComparison.OrdinalIgnoreCase))
        {
            if (args.ShiftKey)
            {
                Redo();
            }
            else
            {
                Undo();
            }

            return;
        }

        if (hasCommandKey && args.Key.Equals("y", StringComparison.OrdinalIgnoreCase))
        {
            Redo();
            return;
        }

        if (hasCommandKey && args.Key.Equals("c", StringComparison.OrdinalIgnoreCase))
        {
            CopySelectedElement();
            return;
        }

        if (hasCommandKey && args.Key.Equals("v", StringComparison.OrdinalIgnoreCase))
        {
            PasteCopiedElement();
            return;
        }

        if (hasCommandKey && args.Key.Equals("d", StringComparison.OrdinalIgnoreCase) && selectedElementId is not null)
        {
            DuplicateElement(selectedElementId);
            return;
        }

        if (args.Key == "Escape")
        {
            ClearSelection();
            return;
        }

        if ((args.Key == "Delete" || args.Key == "Backspace") && selectedElementId is not null)
        {
            DeleteSelectedElement();
            return;
        }

        if (selectedElementId is not null && args.Key.StartsWith("Arrow", StringComparison.OrdinalIgnoreCase))
        {
            var step = args.ShiftKey ? 10 : 1;
            var (deltaX, deltaY) = args.Key switch
            {
                "ArrowLeft" => (-step, 0),
                "ArrowRight" => (step, 0),
                "ArrowUp" => (0, -step),
                "ArrowDown" => (0, step),
                _ => (0, 0)
            };

            if (deltaX != 0 || deltaY != 0)
            {
                NudgeSelectedElement(deltaX, deltaY);
            }
        }
    }

    private void DeleteSelectedElement()
    {
        if (selectedElementId is null || SelectedBox?.IsLocked == true)
        {
            return;
        }

        DeleteElement(selectedElementId);
    }

