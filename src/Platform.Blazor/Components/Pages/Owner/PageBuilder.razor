    private string GetProp(string key, string fallback = "")
    {
        if (SelectedElement?.Props.TryGetPropertyValue(key, out var node) != true)
        {
            return fallback;
        }

        if (node is JsonValue value)
        {
            return value.ToString();
        }

        if (node is JsonArray array)
        {
            return string.Join(", ", array
                .Select(item =>
                {
                    if (item is JsonValue itemValue && itemValue.TryGetValue<string>(out var text))
                    {
                        return text;
                    }

                    return item is JsonObject itemObject
                        ? JsonProps.GetString(itemObject, "text")
                        : null;
                })
                .Where(text => !string.IsNullOrWhiteSpace(text)));
        }

        return fallback;
    }

    private bool GetPropBool(string key, bool fallback = false)
    {
        return SelectedElement?.Props.TryGetPropertyValue(key, out var node) == true &&
               node is JsonValue value &&
               value.TryGetValue<bool>(out var boolean)
            ? boolean
            : fallback;
    }

    private string GetStyle(string key, string fallback = "")
    {
        return SelectedElement?.Styles.TryGetPropertyValue(key, out var node) == true && node is JsonValue value
            ? value.ToString()
            : fallback;
    }

    private void CaptureLiveEdit(string key)
    {
        if (activeLiveEditKey == key)
        {
            return;
        }

        PushHistory();
        activeLiveEditKey = key;
    }

    private void EndLiveEdit()
    {
        activeLiveEditKey = null;
    }

    private void SetProp(string key, object value)
    {
        if (SelectedElement is null)
        {
            return;
        }

        CaptureLiveEdit($"prop:{SelectedElement.Id}:{key}");
        SelectedElement.Props[key] = value switch
        {
            bool boolean => JsonValue.Create(boolean),
            string text when NumericPropKeys.Contains(key) && int.TryParse(text, out var number) => JsonValue.Create(number),
            string text when CommaSeparatedArrayPropKeys.Contains(key) => new JsonArray(
                text.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Select(item => JsonValue.Create(item))
                    .ToArray<JsonNode?>()),
            _ => JsonValue.Create(value.ToString() ?? string.Empty)
        };
        SyncInspectorJson();
        MarkDirty();
    }

    private void HandleInlineEdit(EditorInlineEditRequest request)
    {
        var element = FindElement(request.ElementId);
        if (element is null)
        {
            return;
        }

        selectedElementId = request.ElementId;
        CaptureLiveEdit($"prop:{request.ElementId}:{request.Key}");
        element.Props[request.Key] = JsonValue.Create(request.Value);
        SyncInspectorJson();
        MarkDirty();
    }

    private void SetStyle(string key, string value)
    {
        if (SelectedElement is null)
        {
            return;
        }

        CaptureLiveEdit($"style:{SelectedElement.Id}:{key}");
        if (string.IsNullOrWhiteSpace(value))
        {
            SelectedElement.Styles.Remove(key);
        }
        else
        {
            SelectedElement.Styles[key] = value;
        }

        SyncInspectorJson();
        MarkDirty();
    }

    private void SetLayoutNumber(string key, string value)
    {
        if (key.Equals("snapDistance", StringComparison.OrdinalIgnoreCase))
        {
            SetSnapDistance(value);
            return;
        }

        if (SelectedElement is null || SelectedBox is not { } box)
        {
            return;
        }

        if (!double.TryParse(value, out var number))
        {
            return;
        }

        PushHistory();
        var updated = key switch
        {
            "left" => box with { X = number },
            "top" => box with { Y = number },
            "width" => box with { Width = number },
            "height" => box with { Height = number },
            "zIndex" => box with { ZIndex = (int)Math.Round(number) },
            _ => box
        };

        EditorGeometry.ApplyBox(SelectedElement, EditorGeometry.ClampToCanvas(updated, CanvasModelWidth, Math.Max(CanvasHeight, updated.Y + updated.Height + 96)));
        SyncInspectorJson();
        MarkDirty();
    }

    private void SetSnapDistance(string? value)
    {
        if (double.TryParse(value, out var number))
        {
            snapDistance = Math.Clamp((int)Math.Round(number), 0, 32);
        }
    }

