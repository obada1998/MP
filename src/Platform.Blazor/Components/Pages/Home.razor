@page "/"

<PageTitle>Commerce Platform</PageTitle>

<div class="dashboard-shell">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Multi-Tenant Commerce</h1>
            <div class="text-muted">Operate stores, build JSON pages, and preview storefronts.</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-primary" href="/login">Sign in</a>
            <a class="btn btn-outline-secondary" href="/store/demo-store">Open demo storefront</a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="metric-tile">
                <span>Admin</span>
                <strong>Platform controls</strong>
                <a href="/admin">Open</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-tile">
                <span>Store owner</span>
                <strong>Catalog and pages</strong>
                <a href="/owner">Open</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-tile">
                <span>API</span>
                <strong>REST endpoints</strong>
                <a href="https://localhost:7044/openapi/v1.json" target="_blank">OpenAPI</a>
            </div>
        </div>
    </div>

    <div class="mt-4 row g-3">
        <div class="col-lg-6">
            <div class="panel">
                <h2 class="h5">Seed accounts</h2>
                <table class="table table-sm align-middle mb-0">
                    <tbody>
                        <tr><td>Admin</td><td><code>admin@platform.local</code></td></tr>
                        <tr><td>Owner</td><td><code>owner@demo.local</code></td></tr>
                        <tr><td>Customer</td><td><code>customer@demo.local</code></td></tr>
                        <tr><td>Password</td><td><code>Password123!</code></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="panel">
                <h2 class="h5">Demo paths</h2>
                <div class="list-group list-group-flush">
                    <a class="list-group-item list-group-item-action" href="/owner">Owner dashboard</a>
                    <a class="list-group-item list-group-item-action" href="/store/demo-store/products">Public product listing</a>
                    <a class="list-group-item list-group-item-action" href="/store/demo-store/cart">Cart and checkout placeholder</a>
                </div>
            </div>
        </div>
    </div>
</div>
