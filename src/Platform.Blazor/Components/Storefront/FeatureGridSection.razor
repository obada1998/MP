@using Platform.Blazor.Rendering

<section class="store-feature-section">
    <div class="container">
        <div class="store-section-heading">
            <h2>@Heading</h2>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p>@Subtitle</p>
            }
        </div>
        <div class="store-feature-grid">
            @foreach (var item in Items)
            {
                <article class="store-feature-card">
                    <span>@JsonProps.GetString(item, "icon", "0@")</span>
                    <h3>@JsonProps.GetString(item, "title", "Feature")</h3>
                    <p>@JsonProps.GetString(item, "text", "Describe the benefit or service.")</p>
                </article>
            }
        </div>
    </div>
</section>

@code {
    [Parameter] public PageSectionDefinition Section { get; set; } = new();
    [Parameter] public string StoreKey { get; set; } = string.Empty;

    private string Heading => JsonProps.GetString(Section.Props, "heading", "Features");
    private string Subtitle => JsonProps.GetString(Section.Props, "subtitle");
    private IReadOnlyCollection<JsonObject> Items => JsonProps.GetObjectArray(Section.Props, "items").Count > 0
        ? JsonProps.GetObjectArray(Section.Props, "items")
        : [new JsonObject { ["title"] = "Feature", ["text"] = "Describe the benefit or service." }];
}
