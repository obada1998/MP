@implements IDisposable
@using System.Text.RegularExpressions
@using Platform.Blazor.Rendering

<section class="storefront-image-slider">
    @if (Images.Count == 0)
    {
        <div class="alert alert-light border mb-0">Add images to this slider.</div>
    }
    else
    {
        var current = Images[CurrentIndex];

        <figure class="storefront-image-slider-figure">
            @if (Images.Count > 1)
            {
                <button type="button" class="storefront-image-slider-arrow left" @onclick="PreviousImage" aria-label="Previous image">&#10094;</button>
            }

            <img src="@current.Url" alt="@current.Alt" class="storefront-image-slider-image" style="object-fit:@ObjectFit" />

            @if (Images.Count > 1)
            {
                <button type="button" class="storefront-image-slider-arrow right" @onclick="NextImage" aria-label="Next image">&#10095;</button>
            }

            @if (!string.IsNullOrWhiteSpace(current.Caption))
            {
                <figcaption class="storefront-image-slider-caption">@current.Caption</figcaption>
            }
        </figure>
    }
</section>

@code {
    [Parameter] public PageSectionDefinition Section { get; set; } = new();
    [Parameter] public string StoreKey { get; set; } = string.Empty;

    private int CurrentIndex { get; set; }
    private CancellationTokenSource? AutoPlayCts { get; set; }
    private IReadOnlyList<SliderImage> CachedImages { get; set; } = Array.Empty<SliderImage>();
    private string ObjectFit => JsonProps.GetString(Section.Props, "objectFit", "cover");

    private IReadOnlyList<SliderImage> Images => CachedImages;

    protected override void OnParametersSet()
    {
        CachedImages = BuildImages();
        RestartAutoPlay();
    }

    private void NextImage()
    {
        if (Images.Count == 0)
        {
            return;
        }

        CurrentIndex = (CurrentIndex + 1) % Images.Count;
    }

    private void PreviousImage()
    {
        if (Images.Count == 0)
        {
            return;
        }

        CurrentIndex = (CurrentIndex - 1 + Images.Count) % Images.Count;
    }

    public void Dispose()
    {
        AutoPlayCts?.Cancel();
        AutoPlayCts?.Dispose();
    }

    private void RestartAutoPlay()
    {
        AutoPlayCts?.Cancel();
        AutoPlayCts?.Dispose();
        AutoPlayCts = null;

        if (Images.Count <= 1)
        {
            return;
        }

        AutoPlayCts = new CancellationTokenSource();
        var token = AutoPlayCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested)
                {
                    await Task.Delay(TimeSpan.FromSeconds(4), token);

                    if (token.IsCancellationRequested)
                    {
                        break;
                    }

                    await InvokeAsync(() =>
                    {
                        NextImage();
                        StateHasChanged();
                    });
                }
            }
            catch (TaskCanceledException)
            {
            }
        }, token);
    }

    private IReadOnlyList<SliderImage> BuildImages()
    {
        var fixedUrls = BuildFixedImageUrls();
        if (fixedUrls.Length > 0)
        {
            CurrentIndex = Math.Clamp(CurrentIndex, 0, fixedUrls.Length - 1);
            return fixedUrls.Select((url, idx) => new SliderImage(url, $"Slide {idx + 1}", string.Empty)).ToArray();
        }

        var csv = JsonProps.GetString(Section.Props, "imageUrls", "");
        var urls = ParseImageUrls(csv);

        if (urls.Length > 0)
        {
            CurrentIndex = Math.Clamp(CurrentIndex, 0, urls.Length - 1);
            return urls.Select((url, idx) => new SliderImage(url, $"Slide {idx + 1}", string.Empty)).ToArray();
        }

        if (Section.Props.TryGetPropertyValue("items", out var itemsNode) && itemsNode is JsonArray array)
        {
            var parsed = array
                .OfType<JsonObject>()
                .Select(item => new SliderImage(
                    JsonProps.GetString(item, "url", ""),
                    JsonProps.GetString(item, "alt", ""),
                    JsonProps.GetString(item, "caption", "")))
                .Where(item => !string.IsNullOrWhiteSpace(item.Url))
                .ToArray();

            if (parsed.Length > 0)
            {
                CurrentIndex = Math.Clamp(CurrentIndex, 0, parsed.Length - 1);
                return parsed;
            }
        }

        if (urls.Length == 0)
        {
            urls =
            [
                "https://placehold.co/1200x600?text=Slide+1",
                "https://placehold.co/1200x600?text=Slide+2",
                "https://placehold.co/1200x600?text=Slide+3"
            ];
        }

        CurrentIndex = Math.Clamp(CurrentIndex, 0, urls.Length - 1);

        return urls.Select((url, idx) => new SliderImage(url, $"Slide {idx + 1}", string.Empty)).ToArray();
    }



    private string[] BuildFixedImageUrls()
    {
        var candidates = new[]
        {
            JsonProps.GetString(Section.Props, "imageUrl1", ""),
            JsonProps.GetString(Section.Props, "imageUrl2", ""),
            JsonProps.GetString(Section.Props, "imageUrl3", "")
        };

        return candidates
            .Select(NormalizeUrl)
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Distinct(StringComparer.Ordinal)
            .ToArray();
    }

    private static string[] ParseImageUrls(string raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return Array.Empty<string>();
        }

        var trimmed = raw.Trim();

        // Normalize common pasted HTML line breaks into newlines.
        trimmed = Regex.Replace(trimmed, @"<br\s*/?>", "\n", RegexOptions.IgnoreCase);

        if (trimmed.StartsWith("data:", StringComparison.OrdinalIgnoreCase))
        {
            return [trimmed.Trim('"', '\'', ' ')];
        }

        // Support comma-separated URLs as documented in the page builder UI.
        var separators = new Regex(@"(?:\r\n|\r|\n|;|,(?=\s*(?:https?://|www\.|data:)))", RegexOptions.IgnoreCase);

        var parsed = separators.Split(trimmed)
            .Select(url => url.Trim('"', '\'', ' '))
            .Select(NormalizeUrl)
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Distinct(StringComparer.Ordinal)
            .ToArray();

        if (parsed.Length > 1)
        {
            return parsed;
        }

        // Also support users pasting multiple URLs separated only by whitespace.
        var matches = Regex.Matches(trimmed, @"(?:https?://|www\.)[^\s"'<>]+", RegexOptions.IgnoreCase)
            .Select(match => match.Value.Trim('"', '\'', ' '))
            .Select(NormalizeUrl)
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Distinct(StringComparer.Ordinal)
            .ToArray();

        return matches.Length > 0 ? matches : parsed;
    }

    private static string NormalizeUrl(string url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return string.Empty;
        }

        var normalized = url.Trim().TrimEnd(',', ';');

        if (normalized.StartsWith("//", StringComparison.Ordinal))
        {
            return $"https:{normalized}";
        }

        if (normalized.StartsWith("www.", StringComparison.OrdinalIgnoreCase))
        {
            return $"https://{normalized}";
        }

        if (!normalized.Contains("://", StringComparison.Ordinal) &&
            normalized.Contains('.', StringComparison.Ordinal) &&
            !normalized.StartsWith("/", StringComparison.Ordinal))
        {
            return $"https://{normalized}";
        }

        return normalized;
    }

    private sealed record SliderImage(string Url, string Alt, string Caption);
}
